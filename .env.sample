# Okta tenant — use the Org Authorization Server URL (not /oauth2/default)
OKTA_ORG_URL=https://your-domain.okta.com

# OIDC app (Private Key JWT — no client secret needed)
OKTA_CLIENT_ID=0oa...
OKTA_PRIVATE_KEY_PATH=./keys/private.pem
OKTA_PRIVATE_KEY_ID=your-key-id

# App URLs
APP_BASE_URL=http://localhost:3000
REDIRECT_URI=http://localhost:3000/authorization-code/callback
POST_LOGOUT_REDIRECT_URI=http://localhost:3000

# Session
SESSION_SECRET=change-this-to-a-long-random-string

# Server
PORT=3000
NODE_ENV=development

# Cache duration in hours (default: 1)
CACHE_DURATION_HOURS=1

# Optional: scope metrics per application
# OKTA_APPS=[{"name":"Salesforce","id":"0oa..."},{"name":"Office 365","id":"0oa..."}]
OKTA_APPS=
